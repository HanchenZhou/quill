{
  "name": "@quill/desktop",
  "version": "0.0.2",
  "private": true,
  "description": "Quill desktop app — Markdown editor & preview",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "icon": "node scripts/build-icon.mjs",
    "dist": "bun run icon && electron-vite build && electron-builder",
    "dist:mac": "bun run icon && electron-vite build && electron-builder --mac",
    "dist:mac:arm64": "bun run icon && electron-vite build && electron-builder --mac --arm64",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@quill/shared-types": "workspace:*",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "ai": "^6.0.190",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.16.0",
    "markdown-it": "^14.1.1",
    "zod": "^4.4.3"
  }
}
