{
  "name": "quill",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "bun --filter @quill/desktop dev",
    "build:desktop": "bun --filter @quill/desktop build",
    "dist:desktop": "bun --filter @quill/desktop dist",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test"
  },
  "trustedDependencies": [
    "electron",
    "electron-builder",
    "esbuild"
  ],
  "packageManager": "bun@1.3.6"
}
