{
  "name": "@quill/server",
  "version": "0.0.1",
  "private": true,
  "description": "Quill self-hosted server (Bun + Hono) — auth + vault CRUD + AI agent proxy",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --hot run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@quill/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "hono": "^4.7.0",
    "jose": "^5.9.0",
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
